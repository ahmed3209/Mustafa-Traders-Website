# ─────────────────────────────────────────────────────────────
# Boston PocketSpring Mattress — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# Supabase (database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Server-only. Never expose to the client.

# Email notifications (Resend)
RESEND_API_KEY=
OWNER_EMAIL=                        # Where new-order notifications are sent
RESEND_FROM=                        # Optional. Verified sender, e.g. "Boston Mattress <orders@yourdomain.com>". Defaults to onboarding@resend.dev (test only).

# Admin auth (NextAuth credentials provider)
NEXTAUTH_SECRET=                    # 32+ char random string
NEXTAUTH_URL=http://localhost:3000
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=                # bcrypt hash — generate with `npm run hash:password` (see README)

# Public business config (safe to expose to client)
NEXT_PUBLIC_PHONE=03324989289
NEXT_PUBLIC_WHATSAPP=923324989289   # international format, no +, for wa.me links
NEXT_PUBLIC_GA_MEASUREMENT_ID=      # G-XXXXXXXXXX
NEXT_PUBLIC_TAWK_PROPERTY_ID=       # Tawk.to live-chat property id
